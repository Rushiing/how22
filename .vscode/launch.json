{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: 开发服务器",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Next.js: 附加（需先运行 npm run dev:inspect）",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
